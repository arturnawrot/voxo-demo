# PostgreSQL
POSTGRES_URL=postgresql://postgres:postgres@db:5432/voxo

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Voxo — token from the Voxo portal, tenant ID visible in dashboard/URL
VOXO_API_TOKEN=eyJhbGci...

# OpenAI
OPENAI_API_KEY=sk-...

# How many days back to pull call logs (default 30)
SYNC_LOOKBACK_DAYS=30
